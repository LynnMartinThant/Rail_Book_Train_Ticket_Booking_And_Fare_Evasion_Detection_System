package com.train.booking.rules

import com.train.booking.rules.JourneyDroolsFacts.*
import com.train.booking.config.RouteOrderConfig
import java.time.Instant

global RouteOrderConfig routeOrder
global Instant now

// ========== Layer 1 — Data Validation (salience 100) ==========

rule "Ignore Poor GPS Accuracy"
  salience 100
  when
    $e : LocationEvent(accuracy != null, accuracy > 100)
  then
    retract($e);
end

rule "Duplicate Location Event"
  salience 100
  when
    $e1 : LocationEvent($user : userId, $time1 : timestampEpochMillis)
    $e2 : LocationEvent(userId == $user, timestampEpochMillis == $time1, this != $e1)
  then
    retract($e2);
end

// ========== Layer 2 — Journey Reconstruction (salience 80) ==========

rule "Station Entry"
  salience 80
  when
    $e : LocationEvent($station : stationId, type == "ENTER")
  then
    insert(new StationVisit($e.getUserId(), $station, "ENTER", $e.getTimestampEpochMillis()));
end

rule "Station Exit"
  salience 80
  when
    $e : LocationEvent($station : stationId, type == "EXIT")
  then
    insert(new StationVisit($e.getUserId(), $station, "EXIT", $e.getTimestampEpochMillis()));
end

rule "Create Journey Segment"
  salience 80
  when
    $exitVisit : StationVisit(type == "EXIT", $user : userId, $origin : stationId, $tExit : timestampEpochMillis)
    $enterVisit : StationVisit(type == "ENTER", userId == $user, $dest : stationId, stationId != $origin, $tEnter : timestampEpochMillis)
    eval($tEnter - $tExit >= 60000 && $tEnter - $tExit <= 7200000)
  then
    insert(new Journey($user, $origin, $dest, $tExit, $tEnter));
end

// ========== Layer 3 — Ticket Verification (salience 60) ==========

rule "No Ticket Travel"
  salience 60
  when
    $j : Journey($user : userId)
    not Ticket(userId == $user, status == "CONFIRMED")
  then
    insert(new FraudAlert($user, "NO_TICKET"));
end

rule "Expired Ticket"
  salience 60
  when
    $t : Ticket(status == "CONFIRMED", expiryTime != null)
    eval(now != null && $t.getExpiryTime().isBefore(now))
  then
    insert(new FraudAlert($t.getUserId(), "EXPIRED_TICKET"));
end

// ========== Layer 4 — Fraud Detection (salience 40) ==========

rule "Over Travel"
  salience 40
  when
    $t : Ticket($user : userId, $dest : destinationStation)
    $j : Journey(userId == $user, $actual : destinationStation)
    eval(routeOrder != null && routeOrder.passedDestination($dest, $actual))
  then
    insert(new FraudAlert($user, "OVER_TRAVEL"));
end

rule "Route Violation"
  salience 40
  when
    $t : Ticket($user : userId, $route : routeId)
    $j : Journey(userId == $user, $actualOrigin : originStation, $actualDest : destinationStation)
    eval($route != null && !$route.equals($actualOrigin + "-" + $actualDest))
  then
    insert(new FraudAlert($user, "WRONG_ROUTE"));
end

rule "Ticket Sharing"
  salience 40
  when
    $t1 : TicketUsage($ticket : ticketId, $user1 : userId)
    $t2 : TicketUsage(ticketId == $ticket, userId != $user1)
  then
    insert(new FraudAlert($user1, "TICKET_SHARING"));
end

rule "Multiple Device Usage"
  salience 40
  when
    $d1 : DeviceLogin($user : userId)
    $d2 : DeviceLogin(userId == $user, deviceId != $d1.getDeviceId())
  then
    insert(new FraudAlert($user, "MULTI_DEVICE_SUSPICIOUS"));
end

// ========== Layer 5 — Risk Scoring (salience 20) ==========

rule "Risk Score Calculation"
  salience 20
  when
    $f : FraudAlert($user : userId)
    $r : RiskScore(userId == $user)
  then
    modify($r) { setScore($r.getScore() + 20) }
end

rule "High Risk Passenger"
  salience 20
  when
    $r : RiskScore(score > 80)
  then
    insert(new InvestigationCase($r.getUserId()));
end
