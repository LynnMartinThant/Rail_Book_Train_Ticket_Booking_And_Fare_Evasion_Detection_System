# Copy to .env.capacitor and adjust for your setup.
# Used when building for mobile: npm run build && REACT_APP_API_URL=<url> from .env.capacitor npx cap sync
#
# Android emulator (backend on host machine):
# REACT_APP_API_URL=http://10.0.2.2:8080/api
#
# iOS simulator (backend on same machine):
# REACT_APP_API_URL=http://localhost:8080/api
#
# Real device (use your computer's LAN IP, e.g. 192.168.1.100):
# REACT_APP_API_URL=http://192.168.1.100:8080/api
#
# If not set, the app uses built-in defaults: 10.0.2.2:8080 (Android) and localhost:8080 (iOS).
